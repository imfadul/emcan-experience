# Public site URL, used for metadataBase/OG tags and canonical links.
NEXT_PUBLIC_SITE_URL=https://experience.emcan.sa

# Optional — analytics stay disabled until this is set.
NEXT_PUBLIC_ANALYTICS_ID=

# Required for the contact form to actually deliver leads — the deployed
# Google Apps Script Web App URL (see apps-script/Code.gs).
LEADS_ENDPOINT_URL=

# Optional shared secret sent to the Apps Script endpoint for basic verification.
LEADS_SHARED_SECRET=
